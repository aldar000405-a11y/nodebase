{
    "$schema":  "https://biomejs.dev/schemas/2.2.0/schema.json",
    "vcs":  {
                "enabled":  true,
                "clientKind":  "git",
                "useIgnoreFile":  true
            },
    "files":  {
                  "ignoreUnknown":  true,
                  "includes":  [
                                   "**",
                                   "!node_modules",
                                   "!.next",
                                   "!dist",
                                   "!build",
                                   "!src/components/ui/**",
                                   "!src/generated/**"
                               ]
              },
    "formatter":  {
                      "enabled":  true,
                      "indentStyle":  "space",
                      "indentWidth":  2
                  },
    "linter":  {
                   "enabled":  true,
                   "rules":  {
                                 "recommended":  true,
                                 "suspicious":  {
                                                    "noUnknownAtRules":  "off"
                                                }
                             },
                   "domains":  {
                                   "next":  "recommended",
                                   "react":  "recommended"
                               }
               },
    "assist":  {
                   "actions":  {
                                   "source":  {
                                                  "organizeImports":  "on"
                                              }
                               }
               },
    "overrides":  [
                      {
                          "includes":  [
                                           "src/app/projects/new/_design-app.tsx",
                                           "src/app/projects/new/_design-custom-components.tsx"
                                       ],
                          "linter":  {
                                         "rules":  {
                                                       "a11y":  {
                                                                    "noLabelWithoutControl":  "off",
                                                                    "noSvgWithoutTitle":  "off",
                                                                    "useValidAnchor":  "off",
                                                                    "useButtonType":  "off",
                                                                    "useAltText":  "off"
                                                                },
                                                       "performance":  {
                                                                           "noImgElement":  "off"
                                                                       }
                                                   }
                                     }
                      }
                  ]
}

