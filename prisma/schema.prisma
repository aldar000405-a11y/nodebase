generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. NEXTAUTH CORE MODELS
// ------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, code])
}

model AuthThrottle {
  id          String    @id @default(cuid())
  scope       String
  key         String
  count       Int       @default(0)
  windowStart DateTime
  windowEnd   DateTime
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([scope, key])
  @@index([scope, windowEnd])
  @@map("auth_throttle")
}

// ------------------------------------------------------
// 2. THE CORE DOMAIN MODELS (UX-to-UI AI PLATFORM)
// ------------------------------------------------------

model Project {
  id          String @id @default(cuid())
  name        String
  platform    String
  status      String
  healthScore Int

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // For the visual Canvas mapping (React Flow)
  journeyNodes Json @default("[]")
  journeyEdges Json @default("[]")

  // Brand identity settings extracted by AI
  brandGuidelines Json?

  // Full 9-step UX Discovery Framework brief
  uxBrief Json?

  // Continuous Iteration Versions
  versions ProjectVersion[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@map("project")
}

model ProjectVersion {
  id         String   @id @default(uuid())
  versionNum Int // e.g., 1, 2, 3 
  name       String? // e.g., "Initial Draft", "Fixing checkout"
  createdAt  DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  uxInputs  UxInput[] // The raw research data (PDFs, text)
  uiSchemas UiSchema[] // The UI screens generated for this version

  @@unique([projectId, versionNum])
  @@map("project_version")
}

model UxInput {
  id            String   @id @default(uuid())
  fileName      String
  fileType      String // e.g., "pdf", "text", "csv"
  fileUrl       String?
  extractedText String?  @db.Text
  createdAt     DateTime @default(now())

  projectVersionId String
  projectVersion   ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)

  @@map("ux_input")
}

model UiSchema {
  id         String   @id @default(uuid())
  screenName String
  screenPath String?
  jsonSchema Json // The magic SDUI JSON output from AI
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projectVersionId String
  projectVersion   ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)

  @@map("ui_schema")
}
